# Manager environment configuration.
# Copy to .env.local and fill in real values. Do NOT commit .env.local.
#
# Note: .env.local is parsed raw (lib/server-env.ts) to avoid Next.js $VAR
# expansion corrupting values such as the bcrypt hash below. Quote any value
# that contains a literal $.

# === Manager admin credentials (required) ===
# Login username for the manager dashboard.
CADDYMGR_ADMIN_USER=admin
# bcrypt hash of the admin password. Generate with e.g.:
#   bun -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('your-password', 14))"
CADDYMGR_ADMIN_PASSWORD_HASH='$2a$14$replace_this_with_a_real_bcrypt_hash_value'

# === Caddy admin API (optional, default: http://localhost:2019) ===
# Used for Caddy HTTP server/route management.
CADDY_ADMIN_ADDR=http://localhost:2019

# === Agent-gateway Admin API (proxy target) ===
# Address of the gateway Admin API site (optional, default: http://localhost:8019).
GATEWAY_ADDR=http://localhost:8019
# HTTP Basic Auth credentials injected on every proxied /api/admin/* request.
# Required: the gateway delegates admin auth to the HTTP layer (Caddy basic_auth
# / agwd auth wrapper), and the manager proxy fail-closes (503) without a user.
GATEWAY_ADMIN_USER=admin
GATEWAY_ADMIN_PASSWORD=changeme

# === Gateway data-plane (runtime public listener), for the ACP Chat page ===
# Where ACP turns/permissions are driven. This is the dispatcher (public)
# listener, NOT the admin API. Only needed if you use the ACP -> Chat page.
# Host must match the dispatcher site's host matcher (the data-plane site
# commonly binds 127.0.0.1 while the admin site binds localhost).
# Optional, default: http://127.0.0.1:8080
GATEWAY_DATAPLANE_ADDR=http://127.0.0.1:8080

# === Caddy read-only servers (optional) ===
# Comma-separated Caddy server IDs the manager treats as read-only.
CADDYMGR_READONLY_SERVER_IDS=

# === Frontend API base URL (optional) ===
# Empty means same origin as the manager.
NEXT_PUBLIC_API_BASE_URL=
